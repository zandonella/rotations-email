{
    "compilerOptions": {
        "composite": false,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "strictNullChecks": true,
        "allowImportingTsExtensions": true,
        "esModuleInterop": true
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules", ".react-email"]
}
